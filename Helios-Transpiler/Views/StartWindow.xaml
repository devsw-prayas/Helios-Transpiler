<Window x:Class="Helios_Transpiler.Views.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Helios_Transpiler.Models"
        xmlns:infra="clr-namespace:Helios_Transpiler.Infrastructure"
        Title="Helios-DLX Transpiler"
        Height="700" Width="1160"
        MinHeight="560" MinWidth="860"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Window.Resources>
        <infra:PinIconConverter           x:Key="PinIconConverter"/>
        <infra:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>

        <Style x:Key="Row" TargetType="ListBoxItem">
            <Setter Property="Background"                 Value="Transparent"/>
            <Setter Property="BorderThickness"            Value="0"/>
            <Setter Property="Padding"                    Value="0"/>
            <Setter Property="Margin"                     Value="0"/>
            <Setter Property="Cursor"                     Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="#101C1C" BorderThickness="0,0,0,1"
                                Padding="20,12">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A1A1A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D2020"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="RowTemplate" DataType="{x:Type models:RecentProject}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="{Binding Name}"
                               Foreground="#D0F0EE"
                               FontFamily="Consolas" FontSize="14"/>
                    <TextBlock Text="{Binding FilePath}"
                               Foreground="#2A6060"
                               FontFamily="Consolas" FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,3,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding LastOpenedDisplay}"
                           Foreground="#1E4444"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,14,0"/>
                <Button Grid.Column="2"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Padding="0"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="G"
                                       Text="{Binding IsPinned, Converter={StaticResource PinIconConverter}}"
                                       FontFamily="Consolas" FontSize="13"
                                       Foreground="#1E4444"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                    <Setter TargetName="G" Property="Foreground" Value="#4EC9B0"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="G" Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </DataTemplate>

        <Style x:Key="FlatList" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="#8ECFC9"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="38"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"         Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0D2020"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1A3A3A"/>
                                <Setter Property="Foreground" Value="#D0F0EE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A2828"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="10" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#060E0E" Offset="0"/>
                <GradientStop Color="#040A0A" Offset="0.6"/>
                <GradientStop Color="#020606" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- Watermark -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,24,8" IsHitTestVisible="False" Panel.ZIndex="0">
                <TextBlock Text="HDS"
                           FontSize="160" FontWeight="Black" FontFamily="Consolas"
                           Foreground="#4EC9B0" Opacity="0.025" LineHeight="145"/>
                <TextBlock Text=".HLX"
                           FontSize="160" FontWeight="Black" FontFamily="Consolas"
                           Foreground="#4EC9B0" Opacity="0.025" LineHeight="145"/>
            </StackPanel>

            <Grid Panel.ZIndex="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Border Grid.Row="0"
                        BorderBrush="#0E1E1E" BorderThickness="0,0,0,1"
                        Background="#060E0E"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="18,0,8,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border Width="2" Height="16" CornerRadius="1" Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#80FFE8" Offset="0"/>
                                        <GradientStop Color="#2A8070" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock Foreground="#4EC9B0"
                                       FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                                       VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock.Text>HELIOS-DLX</TextBlock.Text>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#4EC9B0" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="// transpiler"
                                       Foreground="#1A3A3A" FontSize="12" FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="—" Style="{StaticResource WindowButton}" Click="MinimizeBtn_Click"/>
                            <Button Content="□" Style="{StaticResource WindowButton}" Click="MaximizeBtn_Click"/>
                            <Button Content="✕" Style="{StaticResource CloseButton}"  Click="CloseBtn_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- BODY -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="320"/>
                        <ColumnDefinition Width="1"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT PANEL -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Border Grid.Row="0" BorderBrush="#0E1E1E" BorderThickness="0,0,0,1" Background="#040C0C">
                            <Grid>
                                <TextBlock Text="⌕" Foreground="#1A3A3A" FontSize="20"
                                           FontFamily="Consolas" VerticalAlignment="Center"
                                           Margin="18,0,0,0" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="SearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" Foreground="#D0F0EE"
                                         CaretBrush="#4EC9B0" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="16"
                                         Padding="48,18,16,18"/>
                                <TextBlock Text="search recent projects  (Alt+S)"
                                           Foreground="#0E2424" FontFamily="Consolas" FontSize="16"
                                           Margin="48,0,0,0" IsHitTestVisible="False" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Column headers -->
                        <Border Grid.Row="1" BorderBrush="#0E1E1E" BorderThickness="0,0,0,1" Background="#030A0A">
                            <Grid Margin="20,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Foreground="#4EC9B0" Opacity="0.4"
                                           FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                                           VerticalAlignment="Center" Height="30" Margin="275,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="LAST OPENED"
                                           Foreground="#4EC9B0" Opacity="0.4"
                                           FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                           HorizontalAlignment="Right" Margin="0,0,14,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="0" Text="NAME"
                                    Foreground="#4EC9B0" Opacity="0.4"
                                    FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                                    VerticalAlignment="Center" Margin="0,0,476,0"/>
                            </Grid>
                        </Border>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <ListBox ItemsSource="{Binding PinnedProjects}"
                                         Style="{StaticResource FlatList}"
                                         ItemContainerStyle="{StaticResource Row}"
                                         ItemTemplate="{StaticResource RowTemplate}"
                                         MouseDoubleClick="List_MouseDoubleClick"
                                         SelectedItem="{Binding SelectedRecent}"/>
                                <ListBox ItemsSource="{Binding RecentProjects}"
                                         Style="{StaticResource FlatList}"
                                         ItemContainerStyle="{StaticResource Row}"
                                         ItemTemplate="{StaticResource RowTemplate}"
                                         MouseDoubleClick="List_MouseDoubleClick"
                                         SelectedItem="{Binding SelectedRecent}"/>
                                <StackPanel HorizontalAlignment="Center" Margin="0,64,0,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding PinnedProjects.Count}" Value="0"/>
                                                        <Condition Binding="{Binding RecentProjects.Count}"  Value="0"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="no recent projects"
                                               Foreground="#1A3A3A" FontFamily="Consolas" FontSize="14"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="open or create a project to get started"
                                               Foreground="#0E2424" FontFamily="Consolas" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="3" Background="#030A0A" BorderBrush="#0E1E1E" BorderThickness="0,1,0,0">
                            <TextBlock Foreground="#1A3A3A" FontFamily="Consolas" FontSize="14"
                                       VerticalAlignment="Center" Margin="20,0">
                                <Run Text="{Binding RecentProjects.Count, Mode=OneWay}"/>
                                <Run Text=" recent  ·  "/>
                                <Run Text="{Binding PinnedProjects.Count, Mode=OneWay}"/>
                                <Run Text=" pinned"/>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <Rectangle Grid.Column="1" Fill="#0E1E1E"/>

                    <!-- RIGHT PANEL -->
                    <Border Grid.Column="2" Background="#040C0C">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="28"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="20,20,20,0">
                                <TextBlock Text="START"
                                           Foreground="#4EC9B0" Opacity="0.4"
                                           FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                           Margin="4,0,0,12"/>
                                <Button Style="{StaticResource ActionBtn}" HorizontalAlignment="Stretch"
                                        Command="{Binding NewProjectCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="＋" Foreground="#4EC9B0"
                                                   FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="New project" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionBtn}" HorizontalAlignment="Stretch"
                                        Command="{Binding OpenProjectCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="→" Foreground="#2A6060"
                                                   FontSize="13" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Open project" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionBtn}" HorizontalAlignment="Stretch"
                                        Command="{Binding OpenFolderCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="→" Foreground="#2A6060"
                                                   FontSize="13" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Open folder" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Border Height="1" Background="#0E1E1E" Margin="4,16,4,16"/>
                                <TextBlock Text="PINNED"
                                           Foreground="#4EC9B0" Opacity="0.4"
                                           FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                           Margin="4,0,0,8"
                                           Visibility="{Binding PinnedProjects.Count, Converter={StaticResource CountToVisibilityConverter}}"/>
                                <ItemsControl ItemsSource="{Binding PinnedProjects}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ActionBtn}" HorizontalAlignment="Stretch"
                                                    Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="◆" Foreground="#2A6060"
                                                               FontSize="8" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontFamily="Consolas" FontSize="13"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <Border Background="#030A0A" BorderBrush="#0E1E1E" BorderThickness="0,1,0,0" Margin="0,624,0,0" Grid.RowSpan="2">
                                <DockPanel Margin="16,0">
                                    <TextBlock Text="v1.0.0  ·  hdx"
                                               Foreground="#1A3A3A" FontFamily="Consolas" FontSize="10"
                                               VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                    <Button DockPanel.Dock="Right" Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Padding="0" VerticalAlignment="Center"
                                            HorizontalAlignment="Right" Click="ContinueWithoutCode_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <TextBlock x:Name="Lbl" Text="continue without code →"
                                                           Foreground="#1A3A3A" FontFamily="Consolas" FontSize="10"
                                                           VerticalAlignment="Center"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Lbl" Property="Foreground" Value="#4EC9B0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
