<Window x:Class="Helios_Transpiler.Views.StartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Helios_Transpiler.Models"
        xmlns:infra="clr-namespace:Helios_Transpiler.Infrastructure"
        Title="Helios-DLX Transpiler"
        Height="620" Width="1020"
        MinHeight="480" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <infra:PinIconConverter      x:Key="PinIconConverter"/>
        <infra:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>

        <!-- Row list item -->
        <Style x:Key="Row" TargetType="ListBoxItem">
            <Setter Property="Background"                     Value="Transparent"/>
            <Setter Property="BorderThickness"                Value="0"/>
            <Setter Property="Padding"                        Value="0"/>
            <Setter Property="Margin"                         Value="0"/>
            <Setter Property="Cursor"                         Value="Hand"/>
            <Setter Property="HorizontalContentAlignment"     Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderBrush="{DynamicResource BorderDimBrush}"
                                BorderThickness="0,0,0,1" Padding="14,8">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="{DynamicResource BorderDim}" Opacity="1.2"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background">
                                    <Setter.Value><SolidColorBrush Color="{DynamicResource BorderMid}"/></Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="BorderBrush">
                                    <Setter.Value><SolidColorBrush Color="{DynamicResource AccentDimColor}" Opacity="0.4"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Row data template -->
        <DataTemplate x:Key="RowTemplate" DataType="{x:Type models:RecentProject}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="26"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="{Binding Name}"
                               Foreground="#FFFFFF"
                               FontFamily="Consolas" FontSize="13"/>
                    <TextBlock Text="{Binding FilePath}"
                               Foreground="{DynamicResource AccentBrush}"
                               Opacity="0.5"
                               FontFamily="Consolas" FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding LastOpenedDisplay}"
                           Foreground="{DynamicResource TextDimBrush}"
                           FontFamily="Consolas" FontSize="11"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,12,0"/>
                <!-- Pin button -->
                <Button Grid.Column="2"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand" Padding="0"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock x:Name="G"
                                       Text="{Binding IsPinned, Converter={StaticResource PinIconConverter}}"
                                       FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                    <Setter TargetName="G" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="G" Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- Flat listbox -->
        <Style x:Key="FlatList" TargetType="ListBox">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <!-- ══ ROOT BORDER — rounded + gradient ══ -->
    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="{DynamicResource BgLight}" Offset="0"/>
                <GradientStop Color="{DynamicResource BgMid}"   Offset="0.5"/>
                <GradientStop Color="{DynamicResource BgDark}"  Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- ghost watermark -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,20,10" IsHitTestVisible="False" Panel.ZIndex="0">
                <TextBlock Text="HDS"
                           FontSize="130" FontWeight="Black"
                           FontFamily="Consolas"
                           Foreground="{DynamicResource AccentBrush}"
                           Opacity="0.04" LineHeight="120"/>
                <TextBlock Text=".HLX"
                           FontSize="130" FontWeight="Black"
                           FontFamily="Consolas"
                           Foreground="{DynamicResource AccentBrush}"
                           Opacity="0.04" LineHeight="120"/>
            </StackPanel>

            <Grid Panel.ZIndex="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ── TITLE BAR ── -->
                <Border Grid.Row="0"
                        Background="#441A0830"
                        BorderBrush="{DynamicResource BorderDimBrush}"
                        BorderThickness="0,0,0,1"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="16,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Foreground="{DynamicResource AccentBrush}"
                                       FontSize="13" FontWeight="Black"
                                       FontFamily="Consolas"
                                       VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock.Text>HELIOS-DLX</TextBlock.Text>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="{DynamicResource AccentColor}"
                                                      BlurRadius="14" ShadowDepth="0" Opacity="0.8"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="//  transpiler"
                                       Foreground="{DynamicResource TextDimBrush}"
                                       FontSize="12" FontFamily="Consolas" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="—" Style="{StaticResource WindowButton}" Click="MinimizeBtn_Click"/>
                            <Button Content="□" Style="{StaticResource WindowButton}" Click="MaximizeBtn_Click"/>
                            <Button Content="✕" Style="{StaticResource CloseButton}"  Click="CloseBtn_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── BODY ── -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- LEFT: project list -->
                        <ColumnDefinition Width="2*" MinWidth="280"/>
                        <!-- thin accent separator -->
                        <ColumnDefinition Width="1"/>
                        <!-- RIGHT: actions -->
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <!-- ══ LEFT PANEL ══ -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- search -->
                            <RowDefinition Height="Auto"/>  <!-- col headers -->
                            <RowDefinition Height="*"/>     <!-- list -->
                            <RowDefinition Height="22"/>    <!-- status strip -->
                        </Grid.RowDefinitions>

                        <!-- Search -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource BorderDimBrush}"
                                BorderThickness="0,0,0,1"
                                Background="#220A1A30">
                            <Grid>
                                <TextBox x:Name="SearchBox"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         Foreground="#FFFFFF"
                                         CaretBrush="{DynamicResource AccentBrush}"
                                         BorderThickness="0"
                                         FontFamily="Consolas" FontSize="12"
                                         Padding="14,10"/>
                                <TextBlock Text="search  (Alt+S)"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           FontFamily="Consolas" FontSize="12"
                                           Margin="14,0,0,0"
                                           IsHitTestVisible="False"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- Column headers -->
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource BorderDimBrush}"
                                BorderThickness="0,0,0,1"
                                Background="#110818">
                            <Grid Margin="14,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="26"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="NAME"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Opacity="0.6"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                           VerticalAlignment="Center" Height="24"/>
                                <TextBlock Grid.Column="1" Text="LAST OPENED"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Opacity="0.6"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                           HorizontalAlignment="Right" Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Project list -->
                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <!-- PINNED section -->
                                <TextBlock Text="PINNED"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Opacity="0.5"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                           Margin="14,10,0,2"
                                           Visibility="{Binding PinnedProjects.Count,
                                                        Converter={StaticResource CountToVisibilityConverter}}"/>
                                <ListBox ItemsSource="{Binding PinnedProjects}"
                                         Style="{StaticResource FlatList}"
                                         ItemContainerStyle="{StaticResource Row}"
                                         ItemTemplate="{StaticResource RowTemplate}"
                                         MouseDoubleClick="List_MouseDoubleClick"
                                         SelectedItem="{Binding SelectedRecent}"/>

                                <!-- RECENT section -->
                                <TextBlock Text="RECENT"
                                           Foreground="{DynamicResource AccentBrush}"
                                           Opacity="0.5"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                           Margin="14,10,0,2"
                                           Visibility="{Binding RecentProjects.Count,
                                                        Converter={StaticResource CountToVisibilityConverter}}"/>
                                <ListBox ItemsSource="{Binding RecentProjects}"
                                         Style="{StaticResource FlatList}"
                                         ItemContainerStyle="{StaticResource Row}"
                                         ItemTemplate="{StaticResource RowTemplate}"
                                         MouseDoubleClick="List_MouseDoubleClick"
                                         SelectedItem="{Binding SelectedRecent}"/>

                                <!-- Empty state -->
                                <TextBlock Text="no recent projects"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           FontFamily="Consolas" FontSize="13"
                                           HorizontalAlignment="Center"
                                           Margin="0,48,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding PinnedProjects.Count}" Value="0"/>
                                                        <Condition Binding="{Binding RecentProjects.Count}"  Value="0"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- Status strip -->
                        <Border Grid.Row="3"
                                Background="#110818"
                                BorderBrush="{DynamicResource BorderDimBrush}"
                                BorderThickness="0,1,0,0">
                            <TextBlock Foreground="{DynamicResource TextDimBrush}"
                                       FontFamily="Consolas" FontSize="10"
                                       VerticalAlignment="Center" Margin="14,0">
                                <Run Text="{Binding RecentProjects.Count, Mode=OneWay}"/>
                                <Run Text=" recent  ·  "/>
                                <Run Text="{Binding PinnedProjects.Count, Mode=OneWay}"/>
                                <Run Text=" pinned"/>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- accent separator line -->
                    <Rectangle Grid.Column="1">
                        <Rectangle.Fill>
                            <SolidColorBrush Color="{DynamicResource AccentDimColor}" Opacity="0.25"/>
                        </Rectangle.Fill>
                    </Rectangle>

                    <!-- ══ RIGHT PANEL ══ -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="28"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="16,16,16,0">

                            <!-- section label -->
                            <TextBlock Text="START"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Opacity="0.55"
                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,10"/>

                            <!-- New project -->
                            <Button Style="{StaticResource MenuBarButton}"
                                    HorizontalContentAlignment="Left"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding NewProjectCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="＋"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="New project" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Open project -->
                            <Button Style="{StaticResource MenuBarButton}"
                                    HorizontalContentAlignment="Left"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding OpenProjectCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="→"
                                               FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Open project" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Open folder -->
                            <Button Style="{StaticResource MenuBarButton}"
                                    HorizontalContentAlignment="Left"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding OpenFolderCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="→"
                                               FontSize="13" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Open folder" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- divider -->
                            <Border Height="1"
                                    Background="{DynamicResource BorderDimBrush}"
                                    Margin="0,10,0,10"/>

                            <!-- PINNED quick-open -->
                            <TextBlock Text="PINNED"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Opacity="0.55"
                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                       Margin="0,0,0,6"
                                       Visibility="{Binding PinnedProjects.Count,
                                                    Converter={StaticResource CountToVisibilityConverter}}"/>
                            <ItemsControl ItemsSource="{Binding PinnedProjects}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MenuBarButton}"
                                                HorizontalContentAlignment="Left"
                                                HorizontalAlignment="Stretch"
                                                Command="{Binding DataContext.OpenRecentCommand,
                                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="◆"
                                                           Foreground="{DynamicResource AccentDimBrush}"
                                                           FontSize="8" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="Consolas" FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>

                        <!-- Version / continue strip -->
                        <Border Grid.Row="1"
                                Background="#110818"
                                BorderBrush="{DynamicResource BorderDimBrush}"
                                BorderThickness="0,1,0,0">
                            <DockPanel Margin="14,0">
                                <TextBlock Text="v1.0.0  ·  hdx"
                                           Foreground="{DynamicResource TextDimBrush}"
                                           FontFamily="Consolas" FontSize="10"
                                           VerticalAlignment="Center"
                                           DockPanel.Dock="Left"/>
                                <Button DockPanel.Dock="Right"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Padding="0"
                                        VerticalAlignment="Center" HorizontalAlignment="Right"
                                        Click="ContinueWithoutCode_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock x:Name="Lbl"
                                                       Text="Continue without code →"
                                                       Foreground="{DynamicResource TextDimBrush}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       VerticalAlignment="Center"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Lbl" Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DockPanel>
                        </Border>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
