<Window x:Class="Helios_Transpiler.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Helios-DLX Transpiler"
        Height="820" Width="1440"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="CanResize">

    <Border x:Name="RootBorder" CornerRadius="10" ClipToBounds="True">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#060E0E" Offset="0"/>
                <GradientStop Color="#040A0A" Offset="0.6"/>
                <GradientStop Color="#020606" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- Watermark -->
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="20,0,0,10" IsHitTestVisible="False" Panel.ZIndex="0">
                <TextBlock Text="HDS"
                           FontSize="150" FontWeight="Black" FontFamily="Consolas"
                           Foreground="#4EC9B0" Opacity="0.02" LineHeight="136"/>
                <TextBlock Text=".HLX"
                           FontSize="150" FontWeight="Black" FontFamily="Consolas"
                           Foreground="#4EC9B0" Opacity="0.02" LineHeight="136"/>
            </StackPanel>

            <Grid Panel.ZIndex="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="46"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <!-- TITLE BAR -->
                <Border Grid.Row="0"
                        BorderBrush="#0E1E1E" BorderThickness="0,0,0,1"
                        Background="#060E0E"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="18,0,8,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border Width="2" Height="16" CornerRadius="1" Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#80FFE8" Offset="0"/>
                                        <GradientStop Color="#2A8070" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock Foreground="#4EC9B0"
                                       FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                                       VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock.Text>HELIOS-DLX</TextBlock.Text>
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#4EC9B0" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="// transpiler  ·  "
                                       Foreground="#1A3A3A" FontSize="12" FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TitleProjectLabel"
                                       Text="no project"
                                       Foreground="#2A6060" FontSize="12" FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button Content="—" Style="{StaticResource WindowButton}" Click="MinimizeBtn_Click"/>
                            <Button Content="□" Style="{StaticResource WindowButton}" Click="MaximizeBtn_Click"/>
                            <Button Content="✕" Style="{StaticResource CloseButton}"  Click="CloseBtn_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MENU BAR -->
                <Border Grid.Row="1" Background="#050C0C" BorderBrush="#0E1E1E" BorderThickness="0,0,0,1">
                    <DockPanel Margin="10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                            <Grid>
                                <Button x:Name="FileMenuBtn" Content="File"
                                        Style="{StaticResource MenuBarButton}"
                                        Click="FileMenuBtn_Click"/>
                                <Popup x:Name="FileMenuPopup" StaysOpen="False"
                                       PlacementTarget="{Binding ElementName=FileMenuBtn}"
                                       Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#060E0E" BorderBrush="#1A3A3A" BorderThickness="1"
                                            CornerRadius="6" MinWidth="210" Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.8"/>
                                        </Border.Effect>
                                        <StackPanel Margin="4,6">
                                            <Button Content="New File         Ctrl+N" Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="12,0" Click="NewFile_Click"/>
                                            <Button Content="Save             Ctrl+S" Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="12,0" Click="SaveFile_Click"/>
                                            <Button Content="Save As..."              Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="12,0" Click="SaveAsFile_Click"/>
                                            <Button Content="Close Tab        Ctrl+W" Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="12,0" Click="CloseTab_Click"/>
                                            <Border Height="1" Margin="8,4" Background="#0E1E1E"/>
                                            <Button Content="Open Project..."         Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="12,0" Click="OpenProject_Click"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Grid>
                                <Button x:Name="ViewMenuBtn" Content="View"
                                        Style="{StaticResource MenuBarButton}"
                                        Click="ViewMenuBtn_Click"/>
                                <Popup x:Name="ViewMenuPopup" StaysOpen="False"
                                       PlacementTarget="{Binding ElementName=ViewMenuBtn}"
                                       Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Background="#060E0E" BorderBrush="#1A3A3A" BorderThickness="1"
                                            CornerRadius="6" MinWidth="210" Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Color="#000000" Opacity="0.8"/>
                                        </Border.Effect>
                                        <StackPanel Margin="4,6">
                                            <Button Content="Toggle Project Panel" Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="12,0" Click="ToggleProjectPanel_Click"/>
                                            <Button Content="Toggle IR Panel"      Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="12,0" Click="ToggleIRPanel_Click"/>
                                            <Button Content="Toggle Output Panel"  Style="{StaticResource MenuBarButton}" HorizontalContentAlignment="Left" Padding="12,0" Click="ToggleOutputPanel_Click"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Button Content="Build"       Style="{StaticResource MenuBarButton}" Click="BuildBtn_Click"/>
                            <Button Content="Preferences" Style="{StaticResource MenuBarButton}" Click="PreferencesBtn_Click"/>
                        </StackPanel>

                        <!-- Build button — bigger -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,6,0">
                            <Button Height="26" Padding="18,0"
                                Cursor="Hand" Click="BuildBtn_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" CornerRadius="5" Padding="18,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#0A3030" Offset="0"/>
                                                    <GradientStop Color="#1A6060" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="▶  Build  F5"
                                                   Foreground="#D0F0EE"
                                                   FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#4EC9B0" BlurRadius="12" ShadowDepth="0" Opacity="0.8"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- CONTENT -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="ProjectPanelCol" Width="220" MinWidth="120"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition x:Name="IRPanelCol" Width="340" MinWidth="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- PROJECT PANEL -->
                    <Border Grid.Column="0" BorderThickness="1" Margin="6,6,3,6" CornerRadius="6" Background="#040A0A">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#4EC9B0" Opacity="0.22"/>
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" CornerRadius="6,6,0,0" Background="#050C0C" BorderThickness="0,0,0,1">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#4EC9B0" Opacity="0.22"/>
                                </Border.BorderBrush>
                                <TextBlock Text="PROJECT"
                                           Foreground="#4EC9B0" Opacity="0.4"
                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                           VerticalAlignment="Center" Margin="16,0"/>
                            </Border>
                            <Border Grid.Row="1" CornerRadius="0,0,6,6" Background="#040A0A">
                                <TextBlock Text="no project loaded"
                                           Foreground="#0E2424" FontFamily="Consolas" FontSize="12"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="#0E1E1E" Cursor="SizeWE"
                                  ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>

                    <!-- EDITOR AREA -->
                    <Border Grid.Column="2"
 BorderThickness="1"
                            Margin="6,6,6,6" CornerRadius="6">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#4EC9B0" Opacity="0.22"/>
                        </Border.BorderBrush>
                        <Border.Background>
                            <SolidColorBrush Color="#030909" Opacity="1"/>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" CornerRadius="6,6,0,0"
 BorderThickness="0,0,0,1">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#4EC9B0" Opacity="0.22"/>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <SolidColorBrush Color="#050C0C"/>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                                    <Border Background="#060E0E" BorderBrush="#1A3A3A"
                                            BorderThickness="0,0,1,0" Padding="18,0">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="untitled.hds"
                                                       Foreground="#A0D8D4" FontFamily="Consolas" FontSize="13"
                                                       VerticalAlignment="Center"/>
                                            <Border CornerRadius="3" Padding="5,1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#4EC9B0" Opacity="0.15"/>
                                                </Border.Background>
                                                <TextBlock Text="HDS" Foreground="#4EC9B0"
                                                           FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1" CornerRadius="0,0,6,6" Background="#030909">
                                <TextBlock Text="editor  —  phase 2"
                                           Foreground="#0E2020" FontFamily="Consolas" FontSize="13"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                                  Background="#0E1E1E" Cursor="SizeWE"
                                  ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"/>

                    <!-- IR / OUTPUT PANEL -->
                    <Border Grid.Column="4"
 BorderThickness="1"
                            Margin="6,6,6,6" CornerRadius="6">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#4EC9B0" Opacity="0.22"/>
                        </Border.BorderBrush>
                        <Border.Background>
                            <SolidColorBrush Color="#030909"/>
                        </Border.Background>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" CornerRadius="6,6,0,0"
 BorderThickness="0,0,0,1">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#4EC9B0" Opacity="0.22"/>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <SolidColorBrush Color="#050C0C"/>
                                </Border.Background>
                                <DockPanel Margin="10,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" DockPanel.Dock="Left">
                                        <Border CornerRadius="3" Padding="8,2" Margin="0,0,4,0" Cursor="Hand"
                                                BorderThickness="1">
                                            <Border.Background>
                                                <SolidColorBrush Color="#4EC9B0" Opacity="0.12"/>
                                            </Border.Background>
                                            <Border.BorderBrush>
                                                <SolidColorBrush Color="#4EC9B0" Opacity="0.35"/>
                                            </Border.BorderBrush>
                                            <TextBlock Text="IR" Foreground="#4EC9B0"
                                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                        <Border CornerRadius="3" Padding="8,2" Cursor="Hand">
                                            <TextBlock Text="OUTPUT" Foreground="#1A3A3A"
                                                       FontFamily="Consolas" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                HorizontalAlignment="Right" DockPanel.Dock="Right">
                                        <TextBlock Text="mnemonic" Foreground="#1A3A3A"
                                                   FontFamily="Consolas" FontSize="10"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="hex" Foreground="#1A3A3A"
                                                   FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <Border Grid.Row="1" CornerRadius="0,0,6,6" Background="#030909">
                                <TextBox x:Name="IROutputBox"
                                         Background="Transparent" Foreground="#4EC9B0"
                                         BorderThickness="0" FontFamily="Consolas" FontSize="13"
                                         IsReadOnly="True" AcceptsReturn="True"
                                         TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto"
                                         Padding="14,10" CaretBrush="#4EC9B0"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- STATUS BAR -->
                <Border Grid.Row="3" Background="#040C0C" BorderBrush="#0E1E1E" BorderThickness="0,1,0,0">
                    <DockPanel Margin="14,0">
                        <TextBlock x:Name="StatusText"
                                   Text="no project loaded  ·  use File → Open Project"
                                   Foreground="#1A3A3A" FontFamily="Consolas" FontSize="10"
                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
